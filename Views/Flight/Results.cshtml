@using FlightSearchEngine.Models
@model IEnumerable<object>

@{
    ViewData["Title"] = "Search Results";
}

<h2>Search Results</h2>

<p>
    <a asp-action="Index">Back to Search</a>
</p>

@if (Model == null || !Model.Any())
{
    <p style="color:red;">No results found.</p>
}
else
{
    var firstItem = Model.First();

    if (firstItem is FlightResult)
    {
        <table border="1">
            <thead>
                <tr>
                    <th>FlightId</th>
                    <th>FlightName</th>
                    <th>FlightType</th>
                    <th>Source</th>
                    <th>Destination</th>
                    <th>TotalCost</th>
                </tr>
            </thead>
            <tbody>
                @foreach (FlightResult item in Model)
                {
                    <tr>
                        <td>@item.FlightId</td>
                        <td>@item.FlightName</td>
                        <td>@item.FlightType</td>
                        <td>@item.Source</td>
                        <td>@item.Destination</td>
                        <td>@item.TotalCost</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else if (firstItem is FlightHotelResult)
    {
        <table border="1">
            <thead>
                <tr>
                    <th>FlightId</th>
                    <th>FlightName</th>
                    <th>Source</th>
                    <th>Destination</th>
                    <th>HotelName</th>
                    <th>TotalCost</th>
                </tr>
            </thead>
            <tbody>
                @foreach (FlightHotelResult item in Model)
                {
                    <tr>
                        <td>@item.FlightId</td>
                        <td>@item.FlightName</td>
                        <td>@item.Source</td>
                        <td>@item.Destination</td>
                        <td>@item.HotelName</td>
                        <td>@item.TotalCost</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}